---
import CryptoBackground from "../assets/images/landing/crypto-stats-background.webp";
import IceRiverLogo from "../assets/images/landing/ice-river.webp";
import BitmainLogo from "../assets/images/landing/bitmain.webp";
---

<section class="py-10 overflow-x-hidden bg-white">
    <div class="container mx-auto px-4 max-w-[1400px]">
        <div class="text-center">
            <h2
                class="text-[32px] md:text-[36px] font-bold relative inline-block heading-animate"
            >
                Our Trusted Partners
            </h2>
        </div>

        <div
            class="flex flex-col md:flex-row items-center lg:mb-10 mt-[60px] gap-10"
        >
            <div class="lg:w-1/2 mb-6 lg:mb-0" data-aos="fade-right">
                <p class="font-bold mb-3 text-3xl leading-snug">
                    We Work With the <br />Best Partners
                </p>
                <p class="text-lg">
                    We collaborate with top-tier mining hardware providers like <span
                        class="font-semibold">IceRiver and Bitmain.</span
                    > Our operations use cutting-edge machines, ensuring high efficiency,
                    stability, and performance.
                </p>
            </div>
            <div class="lg:w-1/2" data-aos="fade-left">
                <div
                    class="flex flex-col sm:flex-row justify-center items-center gap-12 w-full"
                >
                    <div
                        class="relative bg-gray-200 overflow-hidden rotate-45 w-[200px] h-[200px] lg:w-[250px] lg:h-[250px] transition-transform lg:mr-[50px] transition-all duration-300 hover:opacity-100 hover:scale-105"
                    >
                        <img
                            src={CryptoBackground.src}
                            alt="Crypto Background"
                            class="absolute inset-0 w-full h-full object-cover"
                        />
                        <div class="absolute inset-0 bg-yellow-300/10"></div>
                        <div
                            class="absolute inset-0 flex justify-center items-center"
                        >
                            <img
                                src={IceRiverLogo.src}
                                alt="iceriver"
                                class="max-w-full max-h-full -rotate-45 grayscale transition-all duration-300 hover:grayscale-0 hover:opacity-100 hover:scale-105"
                            />
                        </div>
                    </div>
                    <div
                        class="relative bg-gray-200 overflow-hidden rotate-45 w-[200px] h-[200px] lg:w-[250px] lg:h-[250px] transition-transform transition-all duration-300 hover:opacity-100 hover:scale-105"
                    >
                        <img
                            src={CryptoBackground.src}
                            alt="Crypto Background"
                            class="absolute inset-0 w-full h-full object-cover"
                        />
                        <div class="absolute inset-0 bg-yellow-300/10"></div>
                        <div
                            class="absolute inset-0 flex justify-center items-center"
                        >
                            <img
                                src={BitmainLogo.src}
                                alt="Bitmain"
                                class="max-w-full max-h-full -rotate-45 grayscale transition-all duration-300 hover:grayscale-0 hover:opacity-100 hover:scale-105"
                            />
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<style>
    .partners-section {
        h2 {
            font-size: 2rem;
            line-height: 1.3;
        }

        .partner-logo {
            max-height: 60px;
            filter: grayscale(100%);
            opacity: 0.8;
            transition: all 0.3s ease-in-out;
        }

        .partner-logo:hover {
            filter: grayscale(0%);
            opacity: 1;
            transform: scale(1.05);
        }

        button {
            border-radius: 0;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }
    }

    .diamond-grid {
        --grid-max-width: 1440px;
        --grid-column-count: 8;
        --grid-gap-count: calc(var(--grid-column-count) / 2 - 1);
        --grid-gap: 16px;
        --grid-unit-width: calc(
            (var(--grid-max-width) - var(--grid-gap) * var(--grid-gap-count)) /
                var(--grid-column-count) * 2
        );
        --sqrt: 1.41421356237;
        --transform-unit-width: calc(var(--grid-unit-width) / var(--sqrt));

        display: grid;
        grid-template-columns: repeat(8, 1fr);
        grid-template-rows: repeat(3, auto);
        gap: var(--grid-gap);
        max-width: var(--grid-max-width);
        width: 100%;
        grid-auto-flow: column;
        grid-template-rows: 1fr;
    }

    @media (max-width: 768px) {
        .diamond-grid {
            grid-template-columns: repeat(
                auto-fill,
                minmax(var(--transform-unit-width), 1fr)
            );
            grid-auto-flow: row;
        }
        .grid-unit {
            width: 100% !important;
        }
    }

    .grid-unit {
        grid-column-end: span 2;
        grid-row-end: span 2;
        display: flex;
        justify-content: center;
        align-items: center;
        width: var(--grid-unit-width);
        height: var(--grid-unit-width);

        .logo-overlay {
            transform: rotate(-45deg);
        }
    }

    .grid-unit a {
        display: flex;
        justify-content: center;
        align-items: center;
        position: relative;
        width: var(--transform-unit-width);
        height: var(--transform-unit-width);
        overflow: hidden;
        background-color: #eee;
        transform: rotate(45deg);
        transition: transform 0.3s ease;
        backface-visibility: hidden;
        transform-style: preserve-3d;
    }

    .grid-unit a:before {
        content: "";
        position: absolute;
        inset: 0;
        background-color: rgba(255, 183, 0, 0.1);
        z-index: 1;
        transition: background-color 0.3s ease;
    }

    .grid-unit img {
        width: 100%;
        height: 100%;
        display: block;
        object-fit: cover;
        transition: transform 0.3s ease;
        z-index: 0;
    }

    .grid-unit span {
        position: absolute;
        inset: 0;
        z-index: 2;
        display: flex;
        justify-content: center;
        align-items: center;
    }

    .grid-unit .logo-overlay {
        max-width: 100%;
        max-height: 100%;
        object-fit: contain;
        transition: transform 0.3s ease;
    }
</style>
