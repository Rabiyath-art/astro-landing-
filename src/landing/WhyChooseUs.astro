import PayHashpower from "../assets/svg/pay-hashpower.svg";
import OwnBuying from "../assets/svg/own-buying.svg";
import Expense from "../assets/svg/expense.svg";
import Flexible from "../assets/svg/flexible.svg";
import FastCrypto from "../assets/svg/fast-crypto.svg";
import MiningHardware from "../assets/svg/mining-hardware.svg";
