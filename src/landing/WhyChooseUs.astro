                            <h5 class="text-[22px] font-bold mt-5">
                                Corporate Orders Welcome
                            </h5>
                            <p>
                                Custom solutions and bulk orders available for
                                businesses seeking large-scale mining.
                            </p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<script is:inline>
    window.addEventListener("DOMContentLoaded", () => {
        const section = document.querySelector("#why-choose-us");
        const scrollArea = document.querySelector(".why-scroll-area");
        const inner = document.querySelector(".scroll-inner");
        if (!section || !scrollArea || !inner) return;

        const isMobile = window.innerWidth < 768;

        if (isMobile) {
            scrollArea.style.height = "auto";
            scrollArea.style.overflow = "visible";
            return;
        }
        inner.innerHTML += inner.innerHTML;
        scrollArea.scrollTop = 1;
        let autoScroll = null;
        let scrollSpeed = 1;
        let userScrolling = false;
        let userScrollTimeout = null;
        scrollArea.style.scrollBehavior = "smooth";

        function startScroll() {
            if (autoScroll || userScrolling) return;
            autoScroll = setInterval(() => {
                scrollArea.scrollTop += scrollSpeed;
                if (scrollArea.scrollTop >= inner.scrollHeight / 2) {
                    scrollArea.style.scrollBehavior = "auto";
                    scrollArea.scrollTop = 1;
                    scrollArea.style.scrollBehavior = "smooth";
                }
            }, 20);
        }

        function stopScroll() {
            clearInterval(autoScroll);
            autoScroll = null;
        }

        function onUserScroll() {
            userScrolling = true;
            stopScroll();
            clearTimeout(userScrollTimeout);
            userScrollTimeout = setTimeout(() => {
                userScrolling = false;
                startScroll();
            }, 1000);
        }

        scrollArea.addEventListener("wheel", onUserScroll, { passive: true });
        scrollArea.addEventListener("touchstart", onUserScroll, {
            passive: true,
        });
        scrollArea.addEventListener("touchmove", onUserScroll, {
            passive: true,
        });
        scrollArea.addEventListener("mousedown", onUserScroll);
        const observer = new IntersectionObserver(
            (entries) => {
                entries.forEach((entry) => {
                    if (entry.isIntersecting) startScroll();
                    else stopScroll();
                });
            },
            { threshold: 0.3 },
        );
        observer.observe(section);
    });
</script>

<style>
    p {
        font-size: 18px;
        color: rgba(0, 0, 0, 0.7);
    }
</style>
