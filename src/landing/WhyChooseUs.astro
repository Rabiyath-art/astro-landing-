                    <div>
                        <div
                            class="relative border border-[#F7D243] shadow-md rounded-xl p-6 text-center mt-8"
                        >
                            <div
                                class="circle-icon absolute -top-6 left-1/2 -translate-x-1/2 w-14 h-14 rounded-full bg-gradient-to-b from-purple-400 to-indigo-600 flex items-center justify-center shadow-lg"
