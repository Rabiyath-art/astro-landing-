---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import SocialMedia from "../../components/SocialMedia.astro";
import ScrollToTop from "../../components/scrollToTop.astro";
const seo = {
    title: "LazyPickaxe | Privacy Policy - Secure Crypto Mining Platform",
    description:
        "Read the LazyPickaxe Privacy Policy to learn how we collect, use, and protect your personal and financial data. Your security and trust are our top priorities in crypto mining services.",
    keywords:
        "LazyPickaxe privacy policy, crypto mining privacy, data protection cryptocurrency, secure mining platform, user data security, AML KYC compliance mining, crypto mining data usage, privacy crypto mining",
};
---

<Layout title={seo.title} description={seo.description} keywords={seo.keywords}>
    <Header />
    <SocialMedia />
    <ScrollToTop />
    <section class="relative pt-[150px] pb-[64px] overflow-hidden">
        <div class="container max-w-[1400px] mx-auto px-4">
            <h1
                class="text-[34px] md:text-[36px] font-bold relative inline-block heading-animate mb-14 text-center w-full"
            >
                Privacy Policy
            </h1>
            <div class="flex flex-col md:flex-row items-start gap-10 md:gap-15">
                <div class="w-full space-y-4 pr-2">
                    <!-- First Section -->
                    <div
                        class="collapse collapse-arrow bg-white border border-gray-200 rounded-xl shadow-sm hover:shadow-md transition-all duration-300"
                    >
                        <input type="radio" name="privacy" checked />
                        <div
                            class="collapse-title text-lg font-semibold text-gray-800"
                        >
                            1. Information We Collect
                        </div>
                        <div
                            class="collapse-content text-[17px] text-gray-600 leading-[28px]"
                        >
                            <p>
                                LazyPickaxe collects data to deliver secure,
                                efficient, and optimized crypto mining services.
                            </p>
                            <ul
                                class="list-disc pl-6 space-y-2 text-gray-600 pt-2"
                            >
                                <li>
                                    <strong>Personal details: </strong>name,
                                    email address, wallet address, and
                                    payment-related information.
                                </li>
                                <li>
                                    <strong>Technical data: </strong> IP address,
                                    device information, browser type, operating system,
                                    and geolocation for security and analytics.
                                </li>
                                <li>
                                    <strong>Usage data:</strong> pages visited, actions
                                    taken on the platform, time spent, and interaction
                                    logs.
                                </li>
                                <li>
                                    <strong>Cookies & tracking data: </strong>
                                    used for analytics, personalization, security,
                                    and improving platform performance.
                                </li>
                            </ul>
                        </div>
                    </div>

                    <!-- Second Section -->
                    <div
                        class="collapse collapse-arrow bg-white border border-gray-200 rounded-xl shadow-sm hover:shadow-md transition-all duration-300"
                    >
                        <input type="radio" name="privacy" />
                        <div
                            class="collapse-title text-lg font-semibold text-gray-800"
                        >
                            2. How We Use Your Information
                        </div>
                        <div
                            class="collapse-content text-[17px] text-gray-600 leading-[28px]"
                        >
                            <p class="mb-2">We use collected data to:</p>
                            <ul class="list-disc pl-6 space-y-2 text-gray-600">
                                <li>
                                    Provide and improve cryptocurrency hashpower
                                    allocation services.
                                </li>
                                <li>
                                    Process payments through secure partners
                                    such as <strong
                                        >Stripe and Lightspark.</strong
                                    >
                                </li>
                                <li>
                                    Detect fraudulent activity and enforce
                                    platform policies.
                                </li>
                                <li>
                                    Communicate updates, confirmations, and
                                    support messages.
                                </li>
                                <li>
                                    Ensure compliance with legal obligations,
                                    including AML/KYC requirements.
                                </li>
                                <li>
                                    Analyze platform usage to improve
                                    performance and reliability.
                                </li>
                            </ul>
                        </div>
                    </div>

                    <!-- Third Section -->
                    <div
                        class="collapse collapse-arrow bg-white border border-gray-200 rounded-xl shadow-sm hover:shadow-md transition-all duration-300"
                    >
                        <input type="radio" name="privacy" />
                        <div
                            class="collapse-title text-lg font-semibold text-gray-800"
                        >
                            3. Sharing Your Information
                        </div>
                        <div
                            class="collapse-content text-[17px] text-gray-600 leading-[28px]"
                        >
                            <p class="mb-2">
                                LazyPickaxe does not sell your personal data. We
                                may share data only with:
                            </p>
                            <ul class="list-disc pl-6 space-y-2 text-gray-600">
                                <li>
                                    Payment processors: Stripe, Lightspark, or
                                    similar.
                                </li>
                                <li>
                                    Hosting partners & infrastructure providers
                                    for running our service.
                                </li>
                                <li>
                                    Analytics services to monitor platform
                                    performance.
                                </li>
                                <li>
                                    Legal authorities, but only when required by
                                    law (e.g., court order or regulatory
                                    inquiry).
                                </li>
                            </ul>
                            <p class="mt-2">
                                All third-party partners must follow strict data
                                protection standards.
                            </p>
                        </div>
                    </div>

                    <!-- Fourth Section -->
                    <div
                        class="collapse collapse-arrow bg-white border border-gray-200 rounded-xl shadow-sm hover:shadow-md transition-all duration-300"
                    >
                        <input type="radio" name="privacy" />
                        <div
                            class="collapse-title text-lg font-semibold text-gray-800"
                        >
                            4. Your Data Rights
                        </div>
                        <div
                            class="collapse-content text-[17px] text-gray-600 leading-[28px]"
                        >
                            <p class="mb-2">You have the right to:</p>
                            <ul class="list-disc pl-6 space-y-2 text-gray-600">
                                <li>
                                    Request access to your stored personal data.
                                </li>
                                <li>
                                    Request correction or deletion of inaccurate
                                    information.
                                </li>
                                <li>
                                    Withdraw consent for non-essential data
                                    processing.
                                </li>
                                <li>
                                    Object to certain processing activities.
                                </li>
                                <li>
                                    File a privacy complaint with the
                                    appropriate authority.
                                </li>
                            </ul>
                            <p class="mt-2">
                                We respect all rights under GDPR, CCPA, and
                                international privacy standards.
                            </p>
                        </div>
                    </div>

                    <!-- Fifth Section -->
                    <div
                        class="collapse collapse-arrow bg-white border border-gray-200 rounded-xl shadow-sm hover:shadow-md transition-all duration-300"
                    >
                        <input type="radio" name="privacy" />
                        <div
                            class="collapse-title text-lg font-semibold text-gray-800"
                        >
                            5. Data Retention
                        </div>
                        <div
                            class="collapse-content text-[17px] text-gray-600 leading-[28px]"
                        >
                            <p class="mb-2">
                                We retain your data only for as long as
                                necessary to:
                            </p>
                            <ul class="list-disc pl-6 space-y-2 text-gray-600">
                                <li>Provide hashpower mining services.</li>
                                <li>
                                    Maintain accurate transaction and payment
                                    records.
                                </li>
                                <li>
                                    Meet financial, tax, and regulatory
                                    requirements.
                                </li>
                            </ul>
                            <p class="mt-2">
                                Inactive accounts may be archived or deleted
                                after extended periods of inactivity.
                            </p>
                        </div>
                    </div>

                    <!-- Sixth Section -->
                    <div
                        class="collapse collapse-arrow bg-white border border-gray-200 rounded-xl shadow-sm hover:shadow-md transition-all duration-300"
                    >
                        <input type="radio" name="privacy" />
                        <div
                            class="collapse-title text-lg font-semibold text-gray-800"
                        >
                            6. Data Security
                        </div>
                        <div
                            class="collapse-content text-[17px] text-gray-600 leading-[28px]"
                        >
                            <p class="mb-2">
                                We use advanced security measures to safeguard
                                your data:
                            </p>
                            <ul class="list-disc pl-6 space-y-2 text-gray-600">
                                <li>HTTPS encryption</li>
                                <li>Secure authentication</li>
                                <li>Data hashing (where applicable)</li>
                                <li>Regular platform monitoring</li>
                            </ul>
                            <p class="mt-2">
                                While we take strong measures, no online service
                                can guarantee 100% protection from cyber
                                threats.
                            </p>
                        </div>
                    </div>

                    <!-- Seventh Section -->
                    <div
                        class="collapse collapse-arrow bg-white border border-gray-200 rounded-xl shadow-sm hover:shadow-md transition-all duration-300"
                    >
                        <input type="radio" name="privacy" />
                        <div
                            class="collapse-title text-lg font-semibold text-gray-800"
                        >
                            7. Third-Party Services
                        </div>
                        <div
                            class="collapse-content text-[17px] text-gray-600 leading-[28px]"
                        >
                            <p class="mb-2">
                                LazyPickaxe may use third-party services such
                                as:
                            </p>
                            <ul class="list-disc pl-6 space-y-2 text-gray-600">
                                <li>Analytics tools</li>
                                <li>Cloud hosting</li>
                                <li>Payment gateways</li>
                                <li>Chat and communication tools</li>
                            </ul>
                            <p class="mt-2">
                                Each provider follows its own privacy policy. We
                                recommend reviewing those service-specific
                                policies for additional clarity.
                            </p>
                        </div>
                    </div>

                    <!-- Eighth Section -->
                    <div
                        class="collapse collapse-arrow bg-white border border-gray-200 rounded-xl shadow-sm hover:shadow-md transition-all duration-300"
                    >
                        <input type="radio" name="privacy" />
                        <div
                            class="collapse-title text-lg font-semibold text-gray-800"
                        >
                            8. Children's Privacy
                        </div>
                        <div
                            class="collapse-content text-[17px] text-gray-600 leading-[28px]"
                        >
                            <ul class="list-disc pl-6 space-y-2 text-gray-600">
                                <li>
                                    LazyPickaxe does not knowingly collect
                                    personal data from children under 18 years
                                    of age.
                                </li>
                                <li>
                                    If you believe a minor has used our
                                    platform, please contact us so we can
                                    promptly remove the information.
                                </li>
                            </ul>
                        </div>
                    </div>

                    <!-- Nighth Section -->
                    <div
                        class="collapse collapse-arrow bg-white border border-gray-200 rounded-xl shadow-sm hover:shadow-md transition-all duration-300"
                    >
                        <input type="radio" name="privacy" />
                        <div
                            class="collapse-title text-lg font-semibold text-gray-800"
                        >
                            9. Changes to This Privacy Policy
                        </div>
                        <div
                            class="collapse-content text-[17px] text-gray-600 leading-[28px]"
                        >
                            <ul class="list-disc pl-6 space-y-2 text-gray-600">
                                <li>
                                    We may update this Privacy Policy from time
                                    to time.
                                </li>
                                <li>
                                    Material changes will be communicated via
                                    email or platform notification.
                                </li>
                                <li>
                                    You are encouraged to review the policy
                                    periodically to stay informed.
                                </li>
                            </ul>
                        </div>
                    </div>

                    <!-- Tenth Section -->
                    <div
                        class="collapse collapse-arrow bg-white border border-gray-200 rounded-xl shadow-sm hover:shadow-md transition-all duration-300"
                    >
                        <input type="radio" name="privacy" />
                        <div
                            class="collapse-title text-lg font-semibold text-gray-800"
                        >
                            10. Contact Information
                        </div>
                        <div
                            class="collapse-content text-[17px] text-gray-600 leading-[28px] space-y-3"
                        >
                            <p class="mb-2">
                                If you have questions or requests regarding
                                privacy,
                            </p>
                            <div
                                class="p-3 bg-gray-50 border border-[#e1dfdf] rounded-lg"
                            >
                                <p class="text-gray-600">
                                    How to Reach LazyPickaxe Support.Follow
                                    these simple steps:
                                    <ul
                                        class="list-disc pl-6 pt-2 space-y-2 text-gray-600"
                                    >
                                        <li>Tap Start Mining</li>
                                        <li>Login</li>
                                        <li>
                                            Open the chat and send us your
                                            message — we’ll respond within 24
                                            hours.
                                        </li>
                                    </ul>
                                </p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>
    <Footer />
</Layout>
