---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import ScrollToTop from "../../components/scrollToTop.astro";
import SocialMedia from "../../components/SocialMedia.astro";
import EmailIcon from "../../assets/svg/email.svg";
import ChatIcon from "../../assets/svg/chat.svg";
import LocationIcon from "../../assets/svg/location.svg";

const seo = {
    title: "Contact LazyPickaxe | Crypto Mining Support",
    description:
        "Contact LazyPickaxe for crypto mining rentals, support, and enterprise solutions. Reach us via email, live chat, or visit us in Dubai.",
    keywords:
        "crypto mining, rent mining rigs, bitcoin mining rigs, litecoin mining, monero mining, dogecoin mining, ravencoin mining, kaspa mining, eco-friendly mining, solar powered mining rigs, mining guidance, corporate mining solutions, lazy pickaxe",
};
---

<Layout title={seo.title} description={seo.description} keywords={seo.keywords}>
    <Header />
    <SocialMedia />
    <section class="relative pt-[150px] pb-[120px] overflow-hidden">
        <div
            class="absolute inset-0 opacity-20 bg-[radial-gradient(#00b4a0_1px,transparent_1px)] [background-size:24px_24px]"
        >
        </div>

        <div class="container max-w-[1200px] mx-auto px-4 relative">
            <div class="text-center mb-10">
                <h1
                    class="text-[34px] md:text-[36px] font-bold relative inline-block heading-animate mb-4 text-center w-full"
                >
                    Contact LazyPickaxe
                </h1>
                <p class="max-w-xl mx-auto text-sm">
                    Whether you're mining solo or scaling enterprise operations,
                    our team is ready to help. Reach out and we’ll respond
                    within 24 hours.
                </p>
            </div>

            <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-stretch">
                <div
                    class="relative rounded-3xl shadow-sm overflow-hidden w-full h-full min-h-[400px] lg:min-h-full order-2 lg:order-1"
                    data-aos="fade-right"
                    data-aos-duration="1000"
                >
                    <iframe
                        src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d28899.217910091284!2d55.3681368205458!3d25.122088432931413!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x3e5f640f1dcd4111%3A0xcb38e7be624792c3!2sNadd%20Hessa%20-%20Dubai%20Silicon%20Oasis%20-%20Dubai%20-%20United%20Arab%20Emirates!5e0!3m2!1sen!2sin!4v1766649213597!5m2!1sen!2sin"
                        width="100%"
                        height="100%"
                        style="border:0;"
                        allowfullscreen=""
                        loading="lazy"
                        referrerpolicy="no-referrer-when-downgrade"></iframe>
                </div>
                <div class="rounded-3xl flex flex-col gap-6 order-1 lg:order-2">
                    <div
                        class="bg-[#0a0f3d] border border-white/10 rounded-2xl p-6 backdrop-blur shadow-lg"
                        data-aos="fade-up"
                        data-aos-duration="400"
                    >
                        <div class="flex items-center gap-3 mb-2">
                            <img
                                src={EmailIcon.src}
                                alt="Email Icon"
                                class="w-6 h-6"
                            />
                            <h3 class="font-semibold text-white">Email</h3>
                        </div>
                        <p class="text-gray-300 fntsz16">
                            <a
                                href="mailto:gkcloudservices@gmail.com"
                                class="hover:underline"
                            >
                                gkcloudservices@gmail.com
                            </a>
                        </p>
                    </div>

                    <div
                        class="bg-[#0a0f3d] border border-white/10 rounded-2xl p-6 backdrop-blur shadow-lg"
                        data-aos="fade-up"
                        data-aos-duration="800"
                    >
                        <div class="flex items-center gap-3 mb-2">
                            <img
                                src={ChatIcon.src}
                                alt="Chat Icon"
                                class="w-10"
                            />
                            <h3 class="font-semibold text-white">Live Chat</h3>
                        </div>
                        <p class="text-gray-300 fntsz16">
                            Click “Try LazyPickaxe” on LazyPickaxe to start a
                            chat. We’ll respond within 24 hours.
                        </p>
                    </div>

                    <div
                        class="bg-[#0a0f3d] border border-white/10 rounded-2xl p-6 backdrop-blur shadow-lg"
                        data-aos="fade-up"
                        data-aos-duration="1200"
                    >
                        <div class="flex items-center gap-3 mb-2">
                            <img
                                src={LocationIcon.src}
                                alt="Location Icon"
                                class="w-6 h-6"
                            />
                            <h3 class="font-semibold text-white">Location</h3>
                        </div>
                        <p class="text-gray-300 fntsz16">
                            Dubai Silcon Oasis, Dubai, United Arab Emirates
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </section>
    <Footer />
    <ScrollToTop />
</Layout>

<style>
    p {
        font-size: 16px;
    }
</style>
