---
import { Schema } from "astro-seo-schema";

const { title, description } = Astro.props;

const baseUrl = "https://lazypickaxe.com";
const pathname = Astro.url.pathname;
const fullUrl = `${baseUrl}${pathname}`;
const segments = pathname.split("/").filter(Boolean);

let schema = null;

const faqItems = [
    {
        question:
            "What is Hashrate and how is it used in cryptocurrency mining?",
        answer: " Hashrate refers to the computational power used for verifying transactions and mining blocks. Higher hashrate increases mining efficiency and potential rewards.",
    },
    {
        question: " What are the different mining algorithms supported?",
        answer: "LazyPickaxe supports the following algorithms and cryptocurrencies: SHA256AsicBoost for Bitcoin and Bitcoin Cash, Scrypt for Litecoin and Dogecoin, RandomXMonero for Monero, Kawpow for Ravencoin, Neoxa, and Clore, KHeavyHash for Kaspa, EtcHash for Ethereum Classic and Dogether, and Equihash for Zcash.",
    },
    {
        question:
            " How can I set up my own worker in the mining pool configuration?",
        answer: " To set up a worker, enter the pool URL and worker name in the Mining Pool Configuration section. The worker name is typically used to monitor your mining activity within the pool.",
    },
    {
        question: "How do I verify my mining pool?",
        answer: " To verify your mining pool, ensure that you have entered the correct pool URL and worker details. Click the `Verify` button to initiate the verification process.",
    },
    {
        question: "Do we support node mining?",
        answer: "No, we do not support node mining. Our services are designed exclusively for pool mining. Pool mining allows multiple miners to work together to solve blocks and share the rewards, providing a more consistent and reliable mining experience.",
    },
    {
        question: "Where is my Allocation?",
        answer: "To find your Allocation, you can go on the app and select `ALLOCATION`",
    },
    {
        question: "What payment methods are available?",
        answer: "We support Bitcoin, Lightning payments.",
    },
    {
        question: "How to create your crypto wallet with Exodus",
        answer: "To start renting mining rigs on LazyPickaxe, you’ll need a crypto wallet. We recommend Exodus - a secure and beginner-friendly wallet that supports 300+ cryptocurrencies.",
    },
    {
        question: "What is BTC Lightning payment?",
        answer: "BTC Lightning is a second layer to bitcoin's blockchain that proposes to decongest its network by creating micropayment channels off-chain. This allows for faster transactions with lower fees.",
    },
    {
        question: "What is the advantage of joining a mining pool?",
        answer: "Joining a mining pool helps to reduce the volatility of your payouts by providing smaller, more frequent payments rather than a lump sum that you only receive when a block is solved.",
    },
    {
        question:
            "How long does it take for my mining session to start after payment?",
        answer: "After successful payment, your mining session will typically begin within a few minutes. However, the exact time may vary depending on the network congestion and transaction confirmation time.",
    },
];

if (pathname === "/") {
    schema = {
        "@context": "https://schema.org",
        "@graph": [
            {
                "@type": "Organization",
                "@id": `${baseUrl}/#organization`,
                name: "LazyPickaxe",
                url: baseUrl,
                logo: `${baseUrl}/black-logo.webp`,
                description: "Global crypto hashpower rental marketplace.",
                areaServed: "Worldwide",
            },

            {
                "@type": "WebSite",
                "@id": `${baseUrl}/#website`,
                url: baseUrl,
                name: "LazyPickaxe",
                publisher: {
                    "@id": `${baseUrl}/#organization`,
                },
            },

            {
                "@type": "Service",
                "@id": `${baseUrl}/#eco-mining`,
                name: "Eco-Friendly Crypto Mining",
                provider: {
                    "@id": `${baseUrl}/#organization`,
                },
                description:
                    "Energy-efficient mining infrastructure designed for sustainable blockchain operations.",
            },

            {
                "@type": "ItemList",
                "@id": `${baseUrl}/#partners`,
                name: "Hardware Partners",
                itemListElement: [
                    {
                        "@type": "ListItem",
                        position: 1,
                        item: {
                            "@type": "Organization",
                            name: "Bitmain",
                            url: "https://www.bitmain.com",
                            sameAs: [
                                "https://www.linkedin.com/company/bitmain/",
                                "https://x.com/BITMAINtech",
                            ],
                        },
                    },
                    {
                        "@type": "ListItem",
                        position: 2,
                        item: {
                            "@type": "Organization",
                            name: "IceRiver",
                            url: "https://www.iceriver.io",
                            sameAs: ["https://x.com/icerivereu"],
                        },
                    },
                ],
            },

            /* WHY CHOOSE US */
            {
                "@type": "ItemList",
                "@id": `${baseUrl}/#why-choose-us`,
                name: "Why Choose LazyPickaxe",
                itemListElement: [
                    {
                        "@type": "ListItem",
                        position: 1,
                        name: "Instant hashpower allocation",
                    },
                    {
                        "@type": "ListItem",
                        position: 2,
                        name: "Transparent marketplace pricing",
                    },
                    {
                        "@type": "ListItem",
                        position: 3,
                        name: "Global mining infrastructure",
                    },
                ],
            },
        ],
    };
} else if (segments[0] === "blog") {
    schema = {
        "@context": "https://schema.org",
        "@graph": [
            {
                "@type": "Article",
                headline: title,
                description: description,
                author: {
                    "@type": "Organization",
                    name: "LazyPickaxe",
                },
                publisher: {
                    "@id": `${baseUrl}/#organization`,
                },
                mainEntityOfPage: {
                    "@type": "WebPage",
                    "@id": fullUrl,
                },
            },
            {
                "@type": "BreadcrumbList",
                itemListElement: segments.map((seg, i) => ({
                    "@type": "ListItem",
                    position: i + 1,
                    name: seg,
                    item: `${baseUrl}/${segments.slice(0, i + 1).join("/")}`,
                })),
            },
        ],
    };
} else if (segments[0] === "faq") {
    schema = {
        "@context": "https://schema.org",
        "@type": "FAQPage",
        mainEntity: faqItems.map((item) => ({
            "@type": "Question",
            name: item.question,
            acceptedAnswer: {
                "@type": "Answer",
                text: item.answer,
            },
        })),
    };
} else if (segments[0] === "contact") {
    schema = {
        "@context": "https://schema.org",
        "@type": "ContactPage",
        name: "Contact LazyPickaxe",
        url: fullUrl,
    };
} else if (segments[0] === "algorithm") {
    const algoName = segments[1];

    schema = {
        "@context": "https://schema.org",
        "@graph": [
            {
                "@type": "WebPage",
                "@id": fullUrl,
                name: `${algoName} Hashpower Rental`,
                description: description,
            },
            {
                "@type": "Service",
                "@id": `${fullUrl}#service`,
                name: `${algoName} Hashpower Rental`,
                serviceType: `${algoName} mining hashpower rental`,
                provider: {
                    "@id": `${baseUrl}/#organization`,
                },
                areaServed: "Worldwide",
                offers: {
                    "@type": "Offer",
                    url: fullUrl,
                    availability: "https://schema.org/InStock",
                },
            },
            {
                "@type": "BreadcrumbList",
                itemListElement: segments.map((seg, i) => ({
                    "@type": "ListItem",
                    position: i + 1,
                    name: seg,
                    item: `${baseUrl}/${segments.slice(0, i + 1).join("/")}`,
                })),
            },
        ],
    };
} else {
    schema = {
        "@context": "https://schema.org",
        "@type": "WebPage",
        name: title,
        description: description,
        url: fullUrl,
    };
}
---

<Schema item={schema} />
