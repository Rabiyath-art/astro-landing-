---
import whiteLogo from "../assets/images/landing/white-logo.webp";

const currentPath = Astro.url.pathname;

const isChildActive = (children: any[]) =>
    children?.some((child: { link: string }) => currentPath === child.link);

const navItems = [
    { label: "Home", link: "/" },
    {
        label: "Learn",
        children: [
            { label: "Eco Mining", link: "/#eco-mining" },
            { label: "Our Partners", link: "/#our-partners" },
            { label: "Testimonials", link: "/#testimonials" },
            { label: "Why Choose Us", link: "/#why-choose-us" },
        ],
    },
    {
        label: "Help",
        children: [
            { label: "FAQ", link: "/faq" },
            { label: "Guidance", link: "/guidance" },
        ],
    },
    { label: "Blog", link: "/blog" },
    { label: "Contact us", link: "/contact" },
];
---

<div class="w-full px-4 py-3 fixed top-0 left-0 z-50 lg:flex lg:justify-center">
    <div
        class="w-full max-w-[1400px] rounded-2xl bg-[#0a0f3d] text-white flex items-center justify-between px-6 py-4 shadow-lg"
    >
        <!-- For mobile -->
        <div class="flex items-center gap-4">
            <div class="dropdown lg:hidden">
                <label tabindex="0" class="btn btn-ghost">
                    <svg
                        xmlns="http://www.w3.org/2000/svg"
                        class="h-6 w-6"
                        fill="none"
                        viewBox="0 0 24 24"
                        stroke="currentColor"
                    >
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M4 6h16M4 12h16M4 18h16"></path>
                    </svg>
                </label>

                <ul
                    tabindex="0"
                    class="menu dropdown-content mt-3 left-0 bg-[#0a0f3d] text-white p-4 rounded-none"
                    style="margin-left: -40%;width: 345px; margin-top: 25px;"
                >
                    {
                        navItems.map((item) =>
                            item.children ? (
                                <>
                                    <li class="font-semibold text-[#F7D243] mt-2 pl-3">
                                        {item.label}
                                    </li>
                                    {item.children.map((child) => (
                                        <li class="pl-4 py-1">
                                            <a
                                                href={child.link}
                                                class="hover:text-[#F7D243]"
                                            >
                                                {child.label}
                                            </a>
                                        </li>
                                    ))}
                                </>
                            ) : (
                                <li class="py-1">
                                    <a
                                        href={item.link}
                                        class="hover:text-[#F7D243]"
                                    >
                                        {item.label}
                                    </a>
                                </li>
                            ),
                        )
                    }
                </ul>
            </div>

            <a href="/">
                <img
                    src={whiteLogo.src}
                    class="select-none w-[70px]"
                    alt="LazyPickaxe logo"
                />
            </a>
        </div>

        <!-- For desktop -->
        <div class="hidden lg:flex">
            <ul
                class="menu menu-horizontal text-lg font-medium gap-4 items-center"
            >
                {
                    navItems.map((item) =>
                        item.children ? (
                            <li class="dropdown">
                                <div
                                    tabindex="0"
                                    class={`px-3 py-1 rounded-lg cursor-pointer flex items-center gap-1 transition
                                    ${
                                        isChildActive(item.children)
                                            ? "text-[#F7D243] font-semibold"
                                            : "text-white hover:text-[#F7D243]"
                                    }`}
                                >
                                    {item.label}
                                    <span>▾</span>
                                </div>
                                <ul class="dropdown-content mt-3 p-3 bg-[#0a0f3d] rounded-xl shadow-lg w-56">
                                    {item.children.map((child) => (
                                        <li>
                                            <a
                                                href={child.link}
                                                class="block px-3 py-2 rounded-lg hover:text-[#F7D243]"
                                            >
                                                {child.label}
                                            </a>
                                        </li>
                                    ))}
                                </ul>
                            </li>
                        ) : (
                            <li>
                                <a
                                    href={item.link}
                                    class={`px-3 py-1 rounded-lg transition ${
                                        currentPath === item.link
                                            ? "text-[#F7D243] font-semibold"
                                            : "text-white hover:text-[#F7D243]"
                                    }`}
                                >
                                    {item.label}
                                </a>
                            </li>
                        ),
                    )
                }
            </ul>
        </div>

        <div>
            <a
                href="app/algorithm-list"
                class="btn bg-[#F7D243] text-black font-semibold rounded-full px-5"
            >
                Try LazyPickaxe!
            </a>
        </div>
    </div>
</div>
